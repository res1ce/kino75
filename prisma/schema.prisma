// Prisma Schema для Забайкальской государственной кинокомпании
// PostgreSQL база данных

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Пользователи админ-панели
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(EDITOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

enum Role {
  ADMIN
  EDITOR
}

// Новости
model News {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String   // HTML контент с изображениями
  excerpt     String?
  imageUrl    String?
  published   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("news")
  @@index([publishedAt])
  @@index([published])
}

// Кинотеатры
model Cinema {
  id          String   @id @default(cuid())
  name        String
  address     String
  latitude    Float
  longitude   Float
  link        String?  // Ссылка на сайт или покупку билетов
  phone       String?
  description String?
  imageUrl    String?
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("cinemas")
}

// Противодействие коррупции (файлы)
model AntiCorruption {
  id          String   @id @default(cuid())
  title       String
  description String?
  fileUrl     String   // Путь к файлу
  fileName    String
  fileSize    Int?     // Размер в байтах
  category    String?  // Категория закона
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("anti_corruption")
  @@index([publishedAt])
}

// Прокурор разъясняет (тексты законов)
model ProsecutorExplanation {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String   // Текст закона/разъяснения
  excerpt     String?
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("prosecutor_explanations")
  @@index([publishedAt])
}

// Услуги
model Service {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  price       Float
  unit        String?  // ед. измерения (час, смена, проект)
  category    String?
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("services")
}

// Главная страница (редактируемый контент)
model HomePage {
  id          String   @id @default(cuid())
  key         String   @unique // hero_title, hero_subtitle, about_title, about_content, footer_contacts, footer_description, stats_*
  value       String   // Текст или HTML
  updatedAt   DateTime @updatedAt

  @@map("home_page")
}

// Версия для слабовидящих настройки
model AccessibilitySettings {
  id          String   @id @default(cuid())
  fontSize    String   @default("normal") // normal, large, xlarge
  highContrast Boolean @default(false)
  updatedAt   DateTime @updatedAt

  @@map("accessibility_settings")
}

// Статистика посещений сайта
model VisitStats {
  id          String   @id @default(cuid())
  path        String   // Путь страницы (например, /news, /cinemas)
  userAgent   String?  // User-Agent браузера
  ip          String?  // IP адрес (хэшированный для приватности)
  referer     String?  // Откуда пришел пользователь
  visitedAt   DateTime @default(now())
  createdAt   DateTime @default(now())

  @@map("visit_stats")
  @@index([visitedAt])
  @@index([path])
}
